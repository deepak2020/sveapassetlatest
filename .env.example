# ── Supabase ───────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── AI content generation (optional) ──────────────────────────────────────────
# Only required if you use the admin content-generation modals.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Email — Brevo (free: 300 emails/day) ───────────────────────────────────────
# Sign up at https://brevo.com → API Keys → Create API key
# Also verify your domain (sveapasset.se) under Brevo → Senders & IP → Domains
BREVO_API_KEY=your-brevo-api-key-here

# ── Cron security ─────────────────────────────────────────────────────────────
# Any random string — add to Vercel env vars; Vercel passes it on cron invocations
CRON_SECRET=your-random-secret-here
